{
  "name": "@agentpay/canonical-json",
  "version": "0.0.0",
  "description": "Canonical JSON encoder, decoder, and schema validator for AgentPay signed records (RFC 8785 + AgentPay tightenings).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
