{
  "name": "@agentpay/sdk",
  "version": "0.0.0",
  "description": "AgentPay TypeScript SDK — x402 payments, agent registration, policy management",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentpay/canonical-json": "workspace:*",
    "@noble/curves": "1.8.2",
    "@noble/hashes": "1.7.2",
    "uuid": "11.1.0",
    "viem": "2.53.1"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
