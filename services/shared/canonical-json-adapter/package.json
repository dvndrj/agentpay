{
  "name": "@agentpay/canonical-json-adapter",
  "version": "0.0.0",
  "description": "NestJS adapter wrapping @agentpay/canonical-json for service use",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentpay/canonical-json": "workspace:*",
    "@nestjs/common": "*"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*"
  }
}
