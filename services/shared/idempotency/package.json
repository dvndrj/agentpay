{
  "name": "@agentpay/idempotency",
  "version": "0.0.0",
  "description": "Idempotency-Key interceptor for AgentPay NestJS services",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "*",
    "kysely": "*"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*"
  }
}
